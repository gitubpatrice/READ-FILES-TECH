<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Stockage Android ≤ 12 -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />
    <!--
        MANAGE_EXTERNAL_STORAGE (Android 11+, "Tous les fichiers") :
        REQUISE pour la fonction CŒUR de Read Files Tech : explorateur de
        fichiers universel capable de parcourir, lire et éditer n'importe
        quel fichier sur le stockage partagé (Documents, Download, dossiers
        utilisateur). Le Storage Access Framework (SAF) ne couvre pas
        l'usage "file manager généraliste" (pas de listing arbitraire,
        pas d'accès cross-folders fluide). Aucune lecture/écriture en
        arrière-plan : l'utilisateur reste explicitement aux commandes.
        Documenté dans PRIVACY.md §9.
    -->
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />
    <!-- Médias Android 13+ : preview images/videos/audio dans les viewers. -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />
    <!--
        REQUEST_INSTALL_PACKAGES :
        Permet à l'utilisateur de lancer l'installateur Android (PackageInstaller)
        en tapant sur un fichier .apk depuis l'explorateur — incluant les APK
        de Files Tech (ex: PDF Tech, Pass Tech) qu'il peut transférer
        manuellement entre ses appareils. L'app n'installe RIEN automatiquement :
        c'est l'OS qui prend le relais avec son écran de confirmation.
        Documenté dans PRIVACY.md §9.
    -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    <!-- OCR : capture caméra -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <application
        android:label="Read Files Tech"
        android:name="${applicationName}"
        android:icon="@mipmap/launcher_icon"
        android:allowBackup="false"
        android:fullBackupContent="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:networkSecurityConfig="@xml/network_security_config"
        android:usesCleartextTraffic="false">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <!-- Quick Tiles (volet notification Android, API 24+) -->
        <service
            android:name=".ScannerTileService"
            android:exported="true"
            android:icon="@mipmap/ic_launcher"
            android:label="Scanner Files Tech"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>
        <service
            android:name=".OcrTileService"
            android:exported="true"
            android:icon="@mipmap/ic_launcher"
            android:label="OCR Files Tech"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>
        <service
            android:name=".VaultTileService"
            android:exported="true"
            android:icon="@mipmap/ic_launcher"
            android:label="Coffre Files Tech"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- ML Kit : modèle OCR latin embarqué dans l'APK (pas de download runtime) -->
        <meta-data
            android:name="com.google.mlkit.vision.DEPENDENCIES"
            android:value="ocr" />

        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <!-- Synchronisation avec PDF Tech (édition PDF) -->
        <package android:name="com.pdftech.pdf_tech" />
        <!-- Cloud apps : envoyer un fichier directement -->
        <package android:name="com.infomaniak.drive" />
        <package android:name="me.proton.android.drive" />
        <package android:name="com.google.android.apps.docs" />
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
        <!-- Découverte des apps capables d'installer un APK -->
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:mimeType="application/vnd.android.package-archive"/>
        </intent>
        <!-- Découverte des apps capables d'ouvrir des fichiers de tout type -->
        <intent>
            <action android:name="android.intent.action.VIEW"/>
        </intent>
        <!-- url_launcher Android 11+ : sans ces queries, canLaunchUrl
             retourne false sur https/mailto (lien Apache, contact email…). -->
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <category android:name="android.intent.category.BROWSABLE" />
            <data android:scheme="https" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <category android:name="android.intent.category.BROWSABLE" />
            <data android:scheme="http" />
        </intent>
        <intent>
            <action android:name="android.intent.action.SENDTO" />
            <data android:scheme="mailto" />
        </intent>
    </queries>
</manifest>
