<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+ : exclure toutes les données de l'app du backup cloud + transfert d'appareil.
     Read Files Tech ne stocke pas de données sensibles persistantes mais MANAGE_EXTERNAL_STORAGE
     justifie tout exclure par défense en profondeur. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
