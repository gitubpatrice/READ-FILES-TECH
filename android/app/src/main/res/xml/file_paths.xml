<?xml version="1.0" encoding="utf-8"?>
<!-- Read Files Tech est un explorateur de fichiers : il a besoin d'exposer
     les fichiers utilisateur via FileProvider pour share/open avec d'autres
     apps. external-path="." est nécessaire pour cet usage métier.

     Sécurité :
     - FileProvider exported="false" (uniquement IPC contrôlé)
     - URI individuel grant via FLAG_GRANT_READ_URI_PERMISSION (one-shot,
       révoqué automatiquement à l'exit de l'app cible)
     - Validation côté Kotlin MainActivity (`isAllowedPath`) avec
       canonicalFile (suit symlinks) — refus si hors zone autorisée

     Cache : seul le sous-dossier `share/` est exposé. Le coffre déchiffre
     dans `cache/vault_decrypt/` qui n'est PAS dans cette config — donc
     non partageable directement via FileProvider. Si l'utilisateur veut
     partager un fichier du coffre, il est copié vers `cache/share/` à la
     demande, partagé en URI one-shot, puis purgé. -->
<paths>
    <external-path name="external" path="." />
    <cache-path name="share" path="share/" />
</paths>
